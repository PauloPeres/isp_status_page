# ISP Status Page - Environment Variables
# Copy this to .env and fill in your values

# Application
APP_URL=https://your-domain.com

# Security
SECURITY_SALT=generate-a-random-64-char-hex-string
JWT_SECRET=generate-a-separate-random-64-char-hex-string
APP_DEBUG=false

# Database
POSTGRES_PASSWORD=change-me-in-production

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://redis:6379

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Twilio (SMS + WhatsApp)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567
TWILIO_WHATSAPP_NUMBER=+15551234567
