# UsersController
msgid "You have successfully logged out."
msgstr "Você saiu com sucesso."

msgid "Passwords do not match."
msgstr "As senhas não coincidem."

msgid "User created successfully."
msgstr "Usuário criado com sucesso."

msgid "Unable to create user. Please check the errors below."
msgstr "Não foi possível criar o usuário. Verifique os erros abaixo."

msgid "You do not have permission to edit this user."
msgstr "Você não tem permissão para editar este usuário."

msgid "Profile updated successfully."
msgstr "Perfil atualizado com sucesso."

msgid "Unable to update profile. Please try again."
msgstr "Não foi possível atualizar o perfil. Tente novamente."

msgid "User deleted successfully."
msgstr "Usuário excluído com sucesso."

msgid "Unable to delete user. Please try again."
msgstr "Não foi possível excluir o usuário. Tente novamente."

msgid "For security, you must change your password before continuing."
msgstr "Por segurança, você deve alterar sua senha antes de continuar."

msgid "Please enter your email."
msgstr "Por favor, informe seu email."

msgid "If the email provided is registered, you will receive instructions to reset your password."
msgstr "Se o email informado estiver cadastrado, você receberá as instruções para redefinir sua senha."

msgid "Error processing request. Please try again."
msgstr "Erro ao processar solicitação. Tente novamente."

msgid "Invalid reset token."
msgstr "Token de redefinição inválido."

msgid "Invalid or expired reset token."
msgstr "Token de redefinição inválido ou expirado."

msgid "Reset token expired. Please request a new link."
msgstr "Token de redefinição expirado. Solicite um novo link."

msgid "Please fill in all fields."
msgstr "Por favor, preencha todos os campos."

msgid "Password must be at least 8 characters."
msgstr "A senha deve ter no mínimo 8 caracteres."

msgid "Password reset successfully! You can now log in."
msgstr "Senha redefinida com sucesso! Você já pode fazer login."

msgid "Error resetting password. Please try again."
msgstr "Erro ao redefinir senha. Tente novamente."

msgid "You must be logged in to change your password."
msgstr "Você precisa estar logado para trocar a senha."

msgid "Current password is incorrect."
msgstr "Senha atual incorreta."

msgid "The new password must be different from the current password."
msgstr "A nova senha deve ser diferente da senha atual."

msgid "Password changed successfully! You can now access the system."
msgstr "Senha alterada com sucesso! Você já pode acessar o sistema."

msgid "Error changing password. Please try again."
msgstr "Erro ao alterar senha. Tente novamente."

msgid "Password is required."
msgstr "A senha é obrigatória."

msgid "Invitation email sent successfully."
msgstr "Email de convite enviado com sucesso."

msgid "User created, but there was an error sending the invitation email: "
msgstr "Usuário criado, mas houve erro ao enviar o email de convite: "

