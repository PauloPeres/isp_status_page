# Test Email
msgid "Test Email"
msgstr "Email de Teste"

msgid "Hello!"
msgstr "Olá!"

msgid "This is a test email from the {0} system."
msgstr "Este é um email de teste do sistema {0}."

msgid "Success!"
msgstr "Sucesso!"

msgid "If you are receiving this email, it means the email sending system is configured correctly."
msgstr "Se você está recebendo este email, significa que o sistema de envio de emails está configurado corretamente."

msgid "Email Information:"
msgstr "Informações do Email:"

msgid "Date/Time:"
msgstr "Data/Hora:"

msgid "Timezone:"
msgstr "Fuso horário:"

msgid "System:"
msgstr "Sistema:"

msgid "You can now start sending notifications to your users!"
msgstr "Agora você pode começar a enviar notificações aos seus usuários!"

msgid "This is an automatic test email. No reply is necessary."
msgstr "Este é um email automático de teste. Não é necessário responder."

# Text Email
msgid "TEST EMAIL"
msgstr "EMAIL DE TESTE"

# Subscriber Verification Email
msgid "Welcome!"
msgstr "Bem-vindo!"

msgid "Thank you for subscribing to receive status notifications from {0}."
msgstr "Obrigado por se inscrever para receber notificações de status em {0}."

msgid "To confirm your email {0} and start receiving notifications, please click the button below:"
msgstr "Para confirmar seu email {0} e começar a receber notificações, por favor clique no botão abaixo:"

msgid "Verify My Email"
msgstr "Verificar Meu Email"

msgid "What you will receive:"
msgstr "O que você receberá:"

msgid "Notifications when services go offline"
msgstr "Notificações quando serviços ficarem offline"

msgid "Alerts about ongoing incidents"
msgstr "Alertas sobre incidentes em andamento"

msgid "Confirmations when issues are resolved"
msgstr "Confirmações quando problemas forem resolvidos"

msgid "If you did not subscribe to receive notifications, please ignore this email."
msgstr "Se você não se inscreveu para receber notificações, por favor ignore este email."

msgid "Link not working? Copy and paste this address into your browser:"
msgstr "Link não funciona? Copie e cole este endereço no seu navegador:"

# Email Layout
msgid "This is an automatic email generated by the {0} system"
msgstr "Este é um email automático gerado pelo sistema {0}"

msgid "Please do not reply to this email."
msgstr "Por favor, não responda este email."

msgid "This is an automatic email. Please do not reply."
msgstr "Este é um email automático. Por favor, não responda."
